{
  "activationEvents": [
    "onLanguage:csharp"
  ],
  "categories": [
    "Snippets",
    "Other"
  ],
  "contributes": {
    "commands": [
      {
        "category": "Snipper",
        "command": "snipper.scaffoldConstructor",
        "title": "Snipper: Scaffold constructor"
      },
      {
        "category": "Snipper",
        "command": "snipper.scaffoldProperty",
        "title": "Snipper: Scaffold property"
      },
      {
        "category": "Snipper",
        "command": "snipper.implementInterface",
        "title": "Snipper: Implement interface stub"
      }
    ],
    "configuration": {
      "properties": {
        "snipper.roslynPath": {
          "default": "",
          "markdownDescription": "Path to the `Snipper.Roslyn` sidecar binary. Leave empty to disable C# type-aware filtering.",
          "type": "string"
        },
        "snipper.serverPath": {
          "default": "",
          "markdownDescription": "Path to the `snipper-lsp` binary. Leave empty to use the bundled binary or discover via `PATH`.",
          "type": "string"
        }
      },
      "title": "Snipper"
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "description": "Structural expansion engine — postfix, prefix, surround, and command snippets via LSP.",
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^3.9.1",
    "mocha": "^10.0.0",
    "typescript": "^5.3.0"
  },
  "displayName": "Snipper",
  "engines": {
    "vscode": "^1.85.0"
  },
  "license": "MIT",
  "main": "./out/src/extension.js",
  "name": "snipper-vscode",
  "publisher": "snipper",
  "repository": {
    "type": "git",
    "url": "https://github.com/PhysShell/snipper"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTests.js",
    "vscode:prepublish": "npm run compile",
    "watch": "tsc --watch -p ./"
  },
  "version": "0.0.0"
}
