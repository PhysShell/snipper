<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net472</TargetFramework>
    <OutputType>Library</OutputType>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <RootNamespace>Snipper.VisualStudio</RootNamespace>
    <AssemblyName>Snipper.VisualStudio</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.VisualStudio.Extensibility" Version="17.11.*-*" />
    <PackageReference Include="Microsoft.VisualStudio.SDK" Version="17.0.31902.203" ExcludeAssets="runtime" />
    <PackageReference Include="Microsoft.VSSDK.BuildTools" Version="17.10.*" />
    <PackageReference Include="Nerdbank.Streams" Version="2.*" />
    <PackageReference Include="System.IO.Pipelines" Version="8.*" />
  </ItemGroup>

  <!-- Link the xtask-generated command ID constants -->
  <ItemGroup>
    <Compile Include="..\Generated\SnipperCommands.cs" Link="Generated\SnipperCommands.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="source.extension.vsixmanifest">
      <SubType>Designer</SubType>
    </None>
    <None Include="..\..\..\LICENSE" Link="LICENSE.txt" />
  </ItemGroup>

  <!-- Bundle snipper-lsp.exe when present (staged by CI or placed manually for dev). -->
  <ItemGroup>
    <Content Include="bin\snipper-lsp.exe" Condition="Exists('bin\snipper-lsp.exe')">
      <IncludeInVSIX>true</IncludeInVSIX>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
</Project>
